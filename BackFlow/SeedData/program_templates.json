  "activity_ladder": [
    {
      "level": 1,
      "name": "Keep moving gently",
      "description": "Short walks + gentle mobility. Focus on calm breathing and reducing fear/guarding."
    },
    {
      "level": 2,
      "name": "Build a walking routine",
      "description": "Progress walking minutes/week. Keep symptoms stable using the 24-hour rule."
    },
    {
      "level": 3,
      "name": "Core control basics",
      "description": "Add motor control exercises (dead bug/bird dog/side plank) in low volumes."
    },
    {
      "level": 4,
      "name": "Strength foundations",
      "description": "Add functional strength (sit-to-stand, hinge drill, band anti-rotation)."
    },
    {
      "level": 5,
      "name": "Resilience loading",
      "description": "Progress to light loaded carries and higher volume strength as tolerated."
    },
    {
      "level": 6,
      "name": "Maintain & prevent recurrence",
      "description": "Maintain 2–3 sessions/week + walking habit; watch load spikes."
    }
  ],
